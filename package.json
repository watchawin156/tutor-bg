{
    "name": "tutorm-v2",
    "private": true,
    "version": "1.0.2",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
        "preview": "vite preview",
        "deploy": "wrangler pages deploy dist",
        "all": "npm run build && npm run deploy",
        "d1:setup": "wrangler d1 execute tutor-bg-bd --file=./schema.sql"
    },
    "dependencies": {
        "@pdf-lib/fontkit": "^1.1.1",
        "firebase": "^12.11.0",
        "lucide-react": "^0.479.0",
        "pdf-lib": "^1.17.1",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "wrangler": "^4.76.0",
        "xlsx": "^0.18.5"
    },
    "devDependencies": {
        "@types/react": "^18.3.18",
        "@types/react-dom": "^18.3.5",
        "@vitejs/plugin-react": "^4.3.4",
        "autoprefixer": "^10.4.20",
        "postcss": "^8.5.3",
        "tailwindcss": "^3.4.17",
        "typescript": "^5.7.3",
        "vite": "^6.2.0",
        "vite-plugin-pwa": "^1.2.0"
    }
}